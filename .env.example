# ============================================
# SentinelShield AI Security Platform
# Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

# Application Environment (development/staging/production)
APP_ENV=development

# Groq API Key for LLM-based analysis (optional for pattern-only mode)
GROQ_API_KEY=

# Database URL
# SQLite (default for development):
DATABASE_URL=sqlite+aiosqlite:///./sentinel_shield.db
# PostgreSQL (recommended for production):
# DATABASE_URL=postgresql+asyncpg://sentinel:password@localhost:5432/sentinel_shield

# JWT Authentication
JWT_SECRET_KEY=change-this-to-a-secure-random-string
JWT_EXPIRE_MINUTES=60

# Redis (optional, for caching and rate limiting)
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0

# Logging
LOG_LEVEL=INFO

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8501

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Server Configuration
HOST=0.0.0.0
PORT=8000
